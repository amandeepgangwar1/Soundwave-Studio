{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix backend install",
  "buildCommand": "echo \"No build step required\"",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://soundwave-studio.onrender.com/api/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/:path*"
    }
  ]
}
